{
  "openapi": "3.1.0",
  "info": {
    "title": "Brain Bank API",
    "description": "Semantic memory layer with two retrieval surfaces. Use /pages for entity-shaped queries (synthesized wiki) and /search for moment-shaped queries (raw thoughts). Drill from a wiki page's source thought IDs back to raw thoughts via /search?id=<uuid> (planned, see Phase 12.D).",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://<your-supabase-project-ref>.supabase.co/functions/v1/open-brain-mcp"
    }
  ],
  "paths": {
    "/search": {
      "get": {
        "operationId": "searchThoughts",
        "summary": "Search thoughts by meaning",
        "description": "Semantic vector search across all captured thoughts.",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "What to search for"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" },
            "description": "Max results to return (default 10)"
          },
          {
            "name": "threshold",
            "in": "query",
            "required": false,
            "schema": { "type": "number" },
            "description": "Minimum similarity score 0-1 (default 0.5)"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": { "type": "integer" },
                    "results": { "type": "array", "items": { "type": "object" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/list": {
      "get": {
        "operationId": "listThoughts",
        "summary": "List recent thoughts with optional filters",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" },
            "description": "Max results (default 10)"
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Filter: observation, task, idea, reference, person_note"
          },
          {
            "name": "topic",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Filter by topic tag"
          },
          {
            "name": "person",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Filter by person mentioned"
          },
          {
            "name": "days",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" },
            "description": "Only thoughts from the last N days"
          }
        ],
        "responses": {
          "200": {
            "description": "List of thoughts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": { "type": "integer" },
                    "results": { "type": "array", "items": { "type": "object" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/stats": {
      "get": {
        "operationId": "getThoughtStats",
        "summary": "Get summary statistics of all captured thoughts",
        "responses": {
          "200": {
            "description": "Thought statistics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total": { "type": "integer" },
                    "by_type": { "type": "object" },
                    "by_source": { "type": "object" },
                    "top_topics": { "type": "array", "items": { "type": "object" } },
                    "top_people": { "type": "array", "items": { "type": "object" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/capture": {
      "post": {
        "operationId": "captureThought",
        "summary": "Capture a new thought to Brain Bank",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["content"],
                "properties": {
                  "content": {
                    "type": "string",
                    "description": "The thought to capture"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Capture confirmation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "metadata": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/pages": {
      "get": {
        "operationId": "getCompiledPages",
        "summary": "Read or list wiki pages",
        "description": "When `slug` is provided, returns the full page content for that slug. Otherwise lists pages, optionally filtered by `type` and/or `query` (keyword in title or content). Prefer this over /search for entity-shaped queries about a known client, topic, or project.",
        "parameters": [
          {
            "name": "slug",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Page slug, e.g. 'client/jane-doe' or 'topic/japanese-irezumi'. If provided, returns the full single page; other params are ignored."
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["client", "topic", "project", "index"]
            },
            "description": "Filter list results by page type."
          },
          {
            "name": "query",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Filter list results by keyword in title or content."
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" },
            "description": "Max list results (default 20)."
          }
        ],
        "responses": {
          "200": {
            "description": "Page content (when slug provided) or list of pages.",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "slug": { "type": "string" },
                        "title": { "type": "string" },
                        "page_type": { "type": "string" },
                        "content": { "type": "string" },
                        "backlinks": { "type": "array", "items": { "type": "string" } },
                        "last_compiled": { "type": "string", "format": "date-time" }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "count": { "type": "integer" },
                        "pages": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "slug": { "type": "string" },
                              "title": { "type": "string" },
                              "page_type": { "type": "string" },
                              "last_compiled": { "type": "string", "format": "date-time" }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "No page found for the provided slug."
          }
        }
      }
    }
  }
}
