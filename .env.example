# ──────────────────────────────────────────────────────────────
# Brain Bank: .env.example
#
# Copy this file to .env and fill in your values. The .env file
# is gitignored. Do not paste secrets into .env.example itself.
#
# These vars are what the four Supabase Edge Functions read at
# runtime. You push them to Supabase with:
#
#   supabase secrets set --env-file .env --project-ref <your-project-ref>
#
# The local .env file is also handy for running migrations,
# scripts, and (later) the dashboard in dev mode. Rotate any
# value here by pushing the new value with the same command;
# no code redeploy is needed.
# ──────────────────────────────────────────────────────────────


# ──────────────────────────────────────────────────────────────
# Supabase (required, all four Edge Functions need these)
#
# Every function reads from and writes to your Supabase project.
# These two values authenticate those calls.
# ──────────────────────────────────────────────────────────────

# Project URL.
# Where to find: Supabase Dashboard → Project Settings → API → Project URL.
SUPABASE_URL=https://your-project-ref.supabase.co

# service_role key.
# Where to find: Supabase Dashboard → Project Settings → API → service_role (click "Reveal").
# WHY: Edge Functions need elevated DB access to bypass Row-Level Security on writes.
# Never paste this into client-side code or a public webpage. It grants full read/write
# over your entire database.
SUPABASE_SERVICE_ROLE_KEY=


# ──────────────────────────────────────────────────────────────
# OpenRouter (required, all four Edge Functions call an LLM)
#
# OpenRouter is the gateway for embeddings (text-embedding-3-small),
# metadata extraction (gpt-4o-mini), auto-resolve classification
# (gpt-4.1-mini), and digest synthesis (Claude Sonnet). Set a
# monthly spend cap in the OpenRouter dashboard BEFORE first
# deploy.
# ──────────────────────────────────────────────────────────────

# API key.
# Where to find: openrouter.ai → Keys → "Create Key".
# WHY: typical personal usage runs $5 to $15 per month. A runaway bug could climb
# faster than that, so set OpenRouter's monthly spend cap before connecting this
# key to anything.
OPENROUTER_API_KEY=


# ──────────────────────────────────────────────────────────────
# MCP access key (required, used by 3 of 4 functions plus cron)
#
# This is a shared secret you make up. It gates inbound calls to
# the MCP server and REST API, and pg_cron uses it to call
# compile-pages and brain-digest on schedule.
# ──────────────────────────────────────────────────────────────

# MCP / Brain access key.
# Where to find: generate with `openssl rand -hex 32` and paste the output here.
# WHY: this is the password MCP clients, the dashboard, and the pg_cron jobs use to
# authenticate against your Edge Functions. Also store the same value in Supabase's
# vault as `mcp_access_key` (the deploy walkthrough shows the SQL). Future rotations
# are then a single UPDATE on the vault row, with no cron job edits needed.
MCP_ACCESS_KEY=


# ──────────────────────────────────────────────────────────────
# Slack (required for Slack capture and digest delivery)
#
# If you only plan to capture via MCP or REST and don't want
# the morning digest posted anywhere, you can leave most of
# these blank, BUT ingest-thought won't boot without
# SLACK_BOT_TOKEN and SLACK_CAPTURE_CHANNEL set. The simplest
# path is to create a throwaway Slack workspace for this even
# if you don't use Slack day-to-day.
#
# Full walkthrough: docs/slack-setup.md.
# ──────────────────────────────────────────────────────────────

# Bot User OAuth Token (starts with `xoxb-`).
# Where to find: your Slack App → OAuth & Permissions → Bot User OAuth Token.
SLACK_BOT_TOKEN=

# Signing secret. Used to verify inbound webhook requests really came from Slack.
# Where to find: your Slack App → Basic Information → Signing Secret.
# WHY: without this set, anyone who guesses your Edge Function URL could POST fake
# Slack events and they would be stored as real captures. Leave blank only on a
# throwaway dev deploy.
SLACK_SIGNING_SECRET=

# Primary capture channel ID. This is a channel ID, NOT `#channel-name`.
# Where to find: in Slack, right-click the channel → View channel details → scroll
# to the bottom → copy the Channel ID (format: `C0123456789`).
# WHY: ingest-thought only reads messages posted in this channel. If you point it
# at a channel you chat in normally, every message you send there becomes a
# captured thought.
SLACK_CAPTURE_CHANNEL=

# Secondary capture channel ID (optional, for longer-form thoughts in a separate
# channel). Leave blank if you only use one capture channel.
SLACK_BRAIN_CHANNEL=

# Query channel ID (optional, for @mentioning the bot in Slack to query your memory).
# Leave blank if you don't want a Slack-based query surface.
SLACK_QUERY_CHANNEL=

# Digest delivery channel ID (optional, where the morning digest gets posted).
# Falls back to SLACK_CAPTURE_CHANNEL if left blank.
SLACK_DIGEST_CHANNEL=


# ──────────────────────────────────────────────────────────────
# Notion (optional, enriches the morning digest)
#
# If set, brain-digest pulls extra context from Notion pages
# your integration has access to. Safe to leave blank if you
# don't use Notion.
# ──────────────────────────────────────────────────────────────

# Notion integration token (starts with `secret_` or `ntn_`).
# Where to find: notion.so/profile/integrations → "New integration" → Internal.
# WHY: only needed if you want Notion pages feeding into your digest. The deploy
# walkthrough covers the page-sharing steps the integration expects.
NOTION_API_TOKEN=


# ──────────────────────────────────────────────────────────────
# Dashboard (Phase 5, not enumerated yet)
#
# The Next.js dashboard at ./dashboard/ reads its own set of
# env vars (publishable anon key, MCP URL, cookie password).
# They will be added to this file when the dashboard is merged
# into the monorepo in Phase 5.
# ──────────────────────────────────────────────────────────────
